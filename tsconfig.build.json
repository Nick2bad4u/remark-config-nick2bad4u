{
    "$schema": "https://www.schemastore.org/tsconfig.json",
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": false,
        "isolatedDeclarations": false,
        "isolatedModules": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "noEmit": false,
        "outDir": "./dist",
        "sourceMap": true,
        "tsBuildInfoFile": "./.cache/tsbuildinfo/tsconfig.build.tsbuildinfo",
        "types": [
            "node"
        ]
    },
    "exclude": [
        ".cache/**",
        "dist/**",
        "eslint.config.bundled_*.mjs",
        "node_modules/**",
        "test/fixtures/**"
    ],
    "extends": "./tsconfig.json",
    "include": [
        "index.d.ts",
        "preset.d.mts",
        "remark-plugin-shims.d.ts",
        "eslint.config.mjs",
        "preset.mjs"
    ]
}
